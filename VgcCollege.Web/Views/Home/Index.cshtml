@{
    ViewData["Title"] = "Home";
}

<div class="hero-section">
    <div class="container py-5">
        <div class="text-center text-white">
            <h1 class="display-4 fw-bold mb-3">VGC College</h1>
            <p class="fs-5 mb-4 opacity-75">Ireland's Leading Multi-Branch Education Management System</p>
            @if (!User.Identity!.IsAuthenticated)
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-light btn-lg px-5">Login to Portal</a>
            }
            else
            {
                <p class="fs-6 opacity-75">Welcome back! Use the navigation above.</p>
            }
        </div>
    </div>
</div>

<div class="container mt-5">

    <!-- Stats Bar -->
    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="stat-card text-center p-4">
                <h2 class="fw-bold text-primary mb-1">3</h2>
                <p class="text-muted mb-0">Branches</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card text-center p-4">
                <h2 class="fw-bold text-success mb-1">100+</h2>
                <p class="text-muted mb-0">Students Enrolled</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card text-center p-4">
                <h2 class="fw-bold text-warning mb-1">20+</h2>
                <p class="text-muted mb-0">Courses Available</p>
            </div>
        </div>
    </div>

    <!-- Role Cards -->
    <h3 class="text-center fw-bold mb-4" style="color:#1a1a2e;">Portal Access</h3>
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="role-card admin-card p-4 h-100">
                <div class="role-icon mb-3">⚙️</div>
                <h4 class="fw-bold">Administrator</h4>
                <p class="text-muted small">Full system control — manage branches, courses, students, faculty, attendance and results.</p>
                <span class="badge-custom badge-admin">Full Access</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="role-card faculty-card p-4 h-100">
                <div class="role-icon mb-3">📋</div>
                <h4 class="fw-bold">Faculty</h4>
                <p class="text-muted small">View your students, manage gradebook entries and track academic progress.</p>
                <span class="badge-custom badge-faculty">Course Access</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="role-card student-card p-4 h-100">
                <div class="role-icon mb-3">📚</div>
                <h4 class="fw-bold">Student</h4>
                <p class="text-muted small">Access your courses, view assignment results and check released exam results.</p>
                <span class="badge-custom badge-student">Personal Access</span>
            </div>
        </div>
    </div>

    <!-- Branches -->
    <h3 class="text-center fw-bold mb-4" style="color:#1a1a2e;">Our Locations</h3>
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="branch-card p-4 text-center">
                <div class="branch-icon">D</div>
                <h5 class="fw-bold mt-3">Dublin</h5>
                <p class="text-muted small mb-0">1 Main Street, Dublin</p>
                <p class="text-muted small">Ireland</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="branch-card p-4 text-center">
                <div class="branch-icon">C</div>
                <h5 class="fw-bold mt-3">Cork</h5>
                <p class="text-muted small mb-0">2 High Street, Cork</p>
                <p class="text-muted small">Ireland</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="branch-card p-4 text-center">
                <div class="branch-icon">G</div>
                <h5 class="fw-bold mt-3">Galway</h5>
                <p class="text-muted small mb-0">3 Shop Street, Galway</p>
                <p class="text-muted small">Ireland</p>
            </div>
        </div>
    </div>
</div>