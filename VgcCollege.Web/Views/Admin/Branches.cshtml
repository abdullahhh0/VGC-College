@model IEnumerable<VgcCollege.Web.Models.Branch>
@{ ViewData["Title"] = "Branches"; }

<h2>Branches</h2>
<a asp-action="CreateBranch" class="btn btn-primary mb-3">Add Branch</a>
<table class="table">
    <thead><tr><th>Name</th><th>Address</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var b in Model)
    {
        <tr>
            <td>@b.Name</td>
            <td>@b.Address</td>
            <td>
                <a asp-action="EditBranch" asp-route-id="@b.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="DeleteBranch" asp-route-id="@b.Id" class="btn btn-sm btn-danger"
                   onclick="return confirm('Delete?')">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>