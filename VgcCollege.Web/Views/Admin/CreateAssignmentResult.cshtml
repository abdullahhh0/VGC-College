@{ ViewData["Title"] = "Add Assignment Result"; }

<h2>Add Assignment Result</h2>
<form asp-action="CreateAssignmentResult" method="post">
    <div class="mb-3">
        <label class="form-label">Student</label>
        <select name="StudentProfileId" class="form-select">
            @foreach (var s in ViewBag.Students)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Assignment</label>
        <select name="AssignmentId" class="form-select">
            @foreach (var a in ViewBag.Assignments)
            {
                <option value="@a.Id">@a.Title</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Score</label>
        <input name="Score" type="number" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Feedback</label>
        <input name="Feedback" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="AssignmentResults" class="btn btn-secondary">Cancel</a>
</form>