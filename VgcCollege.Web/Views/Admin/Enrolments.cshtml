@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>
@{ ViewData["Title"] = "Enrolments"; }

<h2>Enrolments</h2>
<a asp-action="CreateEnrolment" class="btn btn-primary mb-3">Add Enrolment</a>
<table class="table">
    <thead><tr><th>Student</th><th>Course</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var e in Model)
    {
        <tr>
            <td>@e.StudentProfile.Name</td>
            <td>@e.Course.Name</td>
            <td>@e.EnrolDate.ToShortDateString()</td>
            <td>@e.Status</td>
            <td>
                <a asp-action="EditEnrolment" asp-route-id="@e.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="DeleteEnrolment" asp-route-id="@e.Id" class="btn btn-sm btn-danger"
                   onclick="return confirm('Delete?')">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>