@model IEnumerable<VgcCollege.Web.Models.AssignmentResult>
@{ ViewData["Title"] = "Assignment Results"; }

<h2>Assignment Results</h2>
<a asp-action="CreateAssignmentResult" class="btn btn-primary mb-3">Add Result</a>
<table class="table">
    <thead><tr><th>Student</th><th>Assignment</th><th>Score</th><th>Feedback</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.StudentProfile.Name</td>
            <td>@r.Assignment.Title</td>
            <td>@r.Score</td>
            <td>@r.Feedback</td>
            <td>
                <a asp-action="DeleteAssignmentResult" asp-route-id="@r.Id" class="btn btn-sm btn-danger"
                   onclick="return confirm('Delete?')">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>