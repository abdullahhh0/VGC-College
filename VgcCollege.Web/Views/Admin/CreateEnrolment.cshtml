@model VgcCollege.Web.Models.CourseEnrolment
@{ ViewData["Title"] = "Add Enrolment"; }

<h2>Add Enrolment</h2>
<form asp-action="CreateEnrolment" method="post">
    <div class="mb-3">
        <label asp-for="StudentProfileId" class="form-label">Student</label>
        <select asp-for="StudentProfileId" class="form-select">
            @foreach (var s in ViewBag.Students)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="CourseId" class="form-label">Course</label>
        <select asp-for="CourseId" class="form-select">
            @foreach (var c in ViewBag.Courses)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label">Status</label>
        <input asp-for="Status" class="form-control" value="Active" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Enrolments" class="btn btn-secondary">Cancel</a>
</form>