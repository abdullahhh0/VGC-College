@model IEnumerable<VgcCollege.Web.Models.ExamResult>
@{ ViewData["Title"] = "Exam Results"; }

<h2>Exam Results</h2>
<a asp-action="CreateExamResult" class="btn btn-primary mb-3">Add Result</a>
<table class="table">
    <thead><tr><th>Student</th><th>Exam</th><th>Score</th><th>Grade</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.StudentProfile.Name</td>
            <td>@r.Exam.Title</td>
            <td>@r.Score</td>
            <td>@r.Grade</td>
            <td>
                <a asp-action="DeleteExamResult" asp-route-id="@r.Id" class="btn btn-sm btn-danger"
                   onclick="return confirm('Delete?')">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>