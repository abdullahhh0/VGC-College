@{ ViewData["Title"] = "Add Exam Result"; }

<h2>Add Exam Result</h2>
<form asp-action="CreateExamResult" method="post">
    <div class="mb-3">
        <label class="form-label">Student</label>
        <select name="StudentProfileId" class="form-select">
            @foreach (var s in ViewBag.Students)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Exam</label>
        <select name="ExamId" class="form-select">
            @foreach (var e in ViewBag.Exams)
            {
                <option value="@e.Id">@e.Title</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Score</label>
        <input name="Score" type="number" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Grade</label>
        <input name="Grade" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="ExamResults" class="btn btn-secondary">Cancel</a>
</form>