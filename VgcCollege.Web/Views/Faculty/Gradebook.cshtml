@model IEnumerable<VgcCollege.Web.Models.AssignmentResult>
@{ ViewData["Title"] = "Gradebook"; }

<h2>Gradebook</h2>
<table class="table">
    <thead><tr><th>Student</th><th>Assignment</th><th>Score</th><th>Feedback</th></tr></thead>
    <tbody>
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.StudentProfile.Name</td>
            <td>@r.Assignment.Title</td>
            <td>@r.Score</td>
            <td>@r.Feedback</td>
        </tr>
    }
    </tbody>
</table>